(function(){
  const carTrack = document.getElementById('carousel-track');
  const cards = Array.from(carTrack.querySelectorAll('.card'));
  const pips = Array.from(document.querySelectorAll('.carousel-pip'));
  let current = 0;

  function goTo(idx){
    current = (idx + cards.length) % cards.length;

    cards.forEach((c,i)=>c.classList.toggle('active', i === current));
    pips.forEach((p,i)=>p.classList.toggle('active', i === current));

    const wrap = carTrack.parentElement;
    const card = cards[current];
    const offset = card.offsetLeft - (wrap.offsetWidth/2) + (card.offsetWidth/2);

    carTrack.style.transform = `translateX(${-offset}px)`;
  }

  setInterval(()=>goTo(current+1), 4000);

  requestAnimationFrame(()=>goTo(0));
})();

